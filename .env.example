# העתק קובץ זה ל-.env.local לפיתוח מקומי, או הגדר את המשתנים האלה ב-Vercel.
# אל תעלה את המפתחות האמיתיים ל-GitHub! (.gitignore כבר חוסם את .env)

# --- קול נוירוני (ElevenLabs) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# מזהה קול (לא חובה). ברירת מחדל עובדת בצרפתית.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- בדיקת תשובות חופשיות (Claude) ---
# מפתח Anthropic לבדיקת השאלות הפתוחות (דקדוק/משמעות/תנאים).
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# מודל הבדיקה (לא חובה). אפשר claude-haiku-4-5 לחיסכון, או claude-sonnet-4-6 לאיכות.
CHECK_MODEL=claude-sonnet-4-6
